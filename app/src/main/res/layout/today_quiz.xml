<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F7"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            >

            <ImageButton
                android:id ="@+id/back_button"
                android:layout_width="140dp"
                android:layout_height="40dp"
                android:src ="@drawable/back1"
                android:scaleType="centerCrop"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivStreakIcon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/str"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true" />

            <TextView
                android:id="@+id/tvStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-40dp"
                android:text="0"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_border_bg"
        android:padding="30dp"
        android:gravity="center_horizontal"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/login"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Quiz"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="30dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartQuiz"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Get Started"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#2D5AA0" /> <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="horizontal">

        <View android:id="@+id/dot_english" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="#888888" />
        <View android:id="@+id/dot_math" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="#888888" />

        <View
            android:id="@+id/dot_science"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="#888888" />

        <View android:id="@+id/dot_social" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="#888888" />
    </LinearLayout>
    </LinearLayout>
</LinearLayout>
