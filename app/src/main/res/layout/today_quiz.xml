<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F7"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="275dp"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:backgroundTint="#EC2328"
            android:text="LOGOUT"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cvStreakBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            app:cardCornerRadius="40dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="20dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <ImageView
                    android:id="@+id/ivStreakIcon"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/str"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-14dp"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_border_bg"
        android:padding="30dp"
        android:gravity="center_horizontal"
        android:elevation="4dp"
        android:layout_marginTop="20dp">

        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/tiger"
            android:layout_marginBottom="20dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Quiz"
            android:fontFamily="@font/montserrat_medium"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR LEVEL IS:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2D5AA0"
            android:fontFamily="@font/montserrat_medium"
            android:gravity="center"
            android:layout_marginTop="0dp" />

        <TextView
            android:id="@+id/tvUserLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESL-1"
            android:fontFamily="@font/montserrat_medium"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2D5AA0"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete one question in each subject to keep your streak going 🔥"
            android:textSize="14sp"
            android:textColor="#666666"
            android:fontFamily="@font/montserrat_medium"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartQuiz"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Get Started"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/montserrat_medium"
            android:backgroundTint="#2D5AA0" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dot_english"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="10dp"
                android:background="@drawable/dot_background" />

            <View
                android:id="@+id/dot_math"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="10dp"
                android:background="@drawable/dot_background" />

            <View
                android:id="@+id/dot_science"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="10dp"
                android:background="@drawable/dot_background" />

            <View
                android:id="@+id/dot_social"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="10dp"
                android:background="@drawable/dot_background" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
