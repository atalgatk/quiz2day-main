<LinearLayout
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        >

        <ImageButton
            android:id ="@+id/back_button"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:src ="@drawable/back1"
            android:scaleType="centerCrop"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <LinearLayout
        android:layout_marginTop="90dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center" >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Daily Dose"
            android:textSize="51sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Select a subject"
            android:textSize="25sp"
            android:layout_marginBottom="30dp"/>

        <!-- Buttons -->
        <Button
            android:id="@+id/english_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="English"
            android:backgroundTint="#0956a4"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/math_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Math"
            android:textSize="30sp"
            android:textStyle="bold"
            android:backgroundTint="#ffc41a"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/science_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Science"
            android:textSize="30sp"
            android:textStyle="bold"
            android:backgroundTint="#168a35"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/ss_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="30sp"
            android:textStyle="bold"
            android:backgroundTint="#ec2328"
            android:text="Social Studies" />

    </LinearLayout>

</LinearLayout>