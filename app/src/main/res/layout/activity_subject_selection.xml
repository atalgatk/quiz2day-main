<LinearLayout
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F0"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_marginTop="70dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:gravity="center_horizontal"
        android:elevation="4dp" >

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Daily Dose..."
            android:textSize="40sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="10dp"/>


        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Select a subject"
            android:textSize="25sp"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="30dp"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/card_border_bg"
            android:elevation="4dp" >

            <Button
                android:id="@+id/english_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="English"
                android:fontFamily="@font/montserrat_medium"
                android:backgroundTint="#0956a4"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/math_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Math"
                android:fontFamily="@font/montserrat_medium"
                android:textSize="28sp"
                android:textStyle="bold"
                android:backgroundTint="#ffc41a"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/science_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Science"
                android:fontFamily="@font/montserrat_medium"
                android:textSize="28sp"
                android:textStyle="bold"
                android:backgroundTint="#168a35"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/ss_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:fontFamily="@font/montserrat_medium"
                android:textStyle="bold"
                android:backgroundTint="#ec2328"
                android:text="Social Studies" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>